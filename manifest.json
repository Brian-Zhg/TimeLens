{
  "manifest_version": 3,
  "name": "LockedIn — Website blocker for productivity",
  "version": "1.0",
  "description": "Block distracting websites with a custom list, focus timer, and password-protected sessions.",
  "action": {
    "default_popup": "basic_toggle.html",
    "default_icon": "tiktok.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "basic_toggle.html",
        "basic_toggle.js",
        "timer.html",
        "timer.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "timer.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["<all_urls>"]
}